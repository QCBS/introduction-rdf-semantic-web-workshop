    dwcdp:spatialLocation <https://bioboum.org/Place123> .

<https://bioboum.org/LabGal123> a dcterms:Agent ;
    dwc:preferredAgentName "Laboratory Lisbeth" .

<https://bioboum.org/Fish123> a dwc:Occurrence ;
